------------------------------------------------------------------------
-- Mobile touch drag
------------------------------------------------------------------------

if isMobile then
    local dragging, dragStart, startPos = false, nil, nil

    win.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = inp.Position
            startPos  = win.Position
        end
    end)

    win.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.Touch then
            local d = inp.Position - dragStart
            win.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)

    win.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

------------------------------------------------------------------------
-- Button events
------------------------------------------------------------------------

minusBtn.MouseButton1Click:Connect(function()
    if cfg.threshold > 2 then
        cfg.threshold   = cfg.threshold - 1
        numDisplay.Text = tostring(cfg.threshold)
    end
end)

plusBtn.MouseButton1Click:Connect(function()
    if cfg.threshold < 20 then
        cfg.threshold   = cfg.threshold + 1
        numDisplay.Text = tostring(cfg.threshold)
    end
end)

toggleBtn.MouseButton1Click:Connect(function()
    cfg.enabled = not cfg.enabled

    if cfg.enabled then
        toggleBtn.Text             = "Stop Hopper"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(95, 26, 52)
        toggleBtn.TextColor3       = Color3.fromRGB(255, 145, 145)
        setStatus("Running, checks every " .. cfg.checkEvery .. "s", 88, 208, 118)
    else
        toggleBtn.Text             = "Start Hopper"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(48, 34, 96)
        toggleBtn.TextColor3       = Color3.fromRGB(185, 165, 255)
        hopping = false
        setStatus("Idle", 138, 138, 138)
    end
end)

------------------------------------------------------------------------
-- Live player count
------------------------------------------------------------------------

local function refreshCount()
    countLbl.Text = "Players in server:  " .. #Players:GetPlayers()
end

Players.PlayerAdded:Connect(refreshCount)
Players.PlayerRemoving:Connect(function()
    task.wait(0.3)
    refreshCount()
end)

------------------------------------------------------------------------
-- Check loop
------------------------------------------------------------------------

task.spawn(function()
    while true do
        task.wait(cfg.checkEvery)
        refreshCount()

        if cfg.enabled and not hopping then
            local n = #Players:GetPlayers()
            if n < cfg.threshold then
                doHop("Only " .. n .. " players here, hopping in 5s...")
            else
                setStatus("Server OK  (" .. n .. " players)", 88, 208, 118)
            end
        end
    end
end)

