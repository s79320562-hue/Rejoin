local me           = Players.LocalPlayer
local placeId      = game.PlaceId
local isMobile     = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

-- all servers we have already been in this session so we skip them
local visited = {}
visited[tostring(game.JobId)] = true

local cfg = {
    threshold  = 5,    -- hop if current server has fewer players than this
    checkEvery = 5,    -- seconds between each check
    enabled    = false,
}

local hopping = false

------------------------------------------------------------------------
-- Utility: fetch a server list page from Roblox public API
------------------------------------------------------------------------

local function fetchServers(cursor)
    local url = "https://games.roblox.com/v1/games/"
        .. tostring(placeId)
        .. "/servers/Public?sortOrder=Desc&excludeFullGames=false&limit=100"

    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end

    -- game:HttpGet works in most executors where HttpService is blocked
    local ok, result = pcall(game.HttpGet, game, url)
    if not ok or not result then
        return nil, nil
    end

    local ok2, decoded = pcall(HttpService.JSONDecode, HttpService, result)
    if not ok2 or type(decoded) ~= "table" then
        return nil, nil
    end

    return decoded.data, decoded.nextPageCursor
end

------------------------------------------------------------------------
-- Pick a server that:
--   1. Has at least cfg.threshold players
--   2. Is not one we have already visited
------------------------------------------------------------------------

local function pickServer()
    local cursor = nil
    local attempts = 0

    repeat
        attempts = attempts + 1
        local servers, nextCursor = fetchServers(cursor)

        if not servers then
            break
        end

        -- shuffle so we do not always land on the same first result
        for i = #servers, 2, -1 do
            local j = math.random(1, i)
            servers[i], servers[j] = servers[j], servers[i]
        end

        for _, s in ipairs(servers) do
            local id      = tostring(s.id or "")
            local playing = tonumber(s.playing) or 0

            if id ~= "" and not visited[id] and playing >= cfg.threshold then
                return id
            end
        end

        cursor = nextCursor

    until not cursor or cursor == "" or attempts >= 4

    return nil
end

------------------------------------------------------------------------
-- Teleport the player to a specific server job ID
------------------------------------------------------------------------

local function teleportTo(jobId)
    -- mark it visited before teleporting so if something fails we do not
    -- try the same one again
    visited[jobId] = true

    local ok, err = pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, jobId, me)
    end)

    return ok, err
end

------------------------------------------------------------------------
-- Main hop function
------------------------------------------------------------------------

local statusLbl  -- forward declare, set after GUI builds
local countLbl

local function setStatus(text, r, g, b)
    if statusLbl then
        statusLbl.Text       = "Status:  " .. text
        statusLbl.TextColor3 = Color3.fromRGB(r or 140, g or 140, b or 140)
    end
end

local function doHop(reason)
    if hopping then return end
    hopping = true

    setStatus(reason, 220, 175, 55)
    task.wait(5) -- 5 second delay before hopping

    local jobId = pickServer()

    if not jobId then
        setStatus("No valid server found, retrying...", 210, 55, 55)
        task.wait(8)
        hopping = false
        return
    end

    setStatus("Hopping to new server...", 255, 150, 45)
    task.wait(1)

    local ok, err = teleportTo(jobId)

    if not ok then
        setStatus("Teleport failed, trying again...", 210, 55, 55)
        task.wait(6)
        hopping = false
    end
    -- if teleport succeeded the game will handle the rest
end

------------------------------------------------------------------------
-- Kick / disconnect detection
------------------------------------------------------------------------

TeleportService.TeleportInitFailed:Connect(function(player, result)
    if not cfg.enabled then return end
    setStatus("Teleport failed, reconnecting in 5s...", 210, 55, 55)
    task.wait(5)
    hopping = false
    doHop("Reconnecting after teleport failure...")
end)

me.OnTeleport:Connect(function(state)
    if state == Enum.TeleportState.Failed then
        if not cfg.enabled then return end
        setStatus("Connection lost, reconnecting in 5s...", 210, 55, 55)
        task.wait(5)
        hopping = false
        doHop("Reconnecting after disconnect...")
    end
end)

-- safety net in case the player gets removed from the game unexpectedly
local heartbeatConn
heartbeatConn = RunService.Heartbeat:Connect(function()
    if not cfg.enabled then return end
    if not me or not me.Parent then
        heartbeatConn:Disconnect()
        setStatus("Removed from game, reconnecting...", 210, 55, 55)
        task.wait(5)
        hopping = false
        doHop("Reconnecting after kick/removal...")
    end
end)

