-- // Find a server with enough players
local function findGoodServer()
    local ok, servers = pcall(function()
        return HttpService:JSONDecode(
            game:HttpGet("https://games.roblox.com/v1/games/" .. RIVALS_PLACE_ID .. "/servers/Public?sortOrder=Desc&limit=100")
        )
    end)

    if not ok or not servers or not servers.data then
        return nil
    end

    -- shuffle so we don't always pick the same one
    local list = servers.data
    for i = #list, 2, -1 do
        local j = math.random(i)
        list[i], list[j] = list[j], list[i]
    end

    for _, s in ipairs(list) do
        -- look for a server with our target or more players
        if s.playing and s.playing >= settings.targetPlayers then
            -- skip the one we're already in
            if s.id ~= game.JobId then
                return s.id
            end
        end
    end

    return nil
end

-- // Hop to a new server
local function doHop()
    statusLbl.TextColor3 = Color3.fromRGB(255, 200, 50)
    statusLbl.Text = "Status:  Searching..."

    task.wait(settings.hopDelay)

    local jobId = findGoodServer()

    if jobId then
        statusLbl.TextColor3 = Color3.fromRGB(255, 160, 60)
        statusLbl.Text = "Status:  Hopping..."
        task.wait(1)

        local success, err = pcall(function()
            TeleportService:TeleportToPlaceInstance(RIVALS_PLACE_ID, jobId, me)
        end)

        if not success then
            statusLbl.TextColor3 = Color3.fromRGB(220, 60, 60)
            statusLbl.Text = "Status:  Teleport failed, retrying..."
            task.wait(4)
        end
    else
        statusLbl.TextColor3 = Color3.fromRGB(220, 60, 60)
        statusLbl.Text = "Status:  No server found, waiting..."
        task.wait(10)
    end
end

-- // Main loop
task.spawn(function()
    while true do
        task.wait(settings.checkInterval)

        -- always keep the player count fresh
        local currentPlayers = #Players:GetPlayers()
        countLbl.Text = "Players in server:  " .. currentPlayers

        if settings.enabled then
            if currentPlayers < settings.targetPlayers then
                doHop()
            else
                statusLbl.TextColor3 = Color3.fromRGB(100, 220, 130)
                statusLbl.Text = "Status:  Server OK (" .. currentPlayers .. " players)"
            end
        end
    end
end)

-- update player count every second passively
